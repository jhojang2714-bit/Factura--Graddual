<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Graddual — Convertidor de Facturas</title>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:system-ui,-apple-system,sans-serif;background:#f8f7ff;color:#1a1a2e;min-height:100vh}
  .app{max-width:660px;margin:0 auto;padding:32px 16px}
  .header{display:flex;align-items:center;gap:12px;margin-bottom:28px}
  .logo-box{background:#1a0a2e;border-radius:10px;padding:9px 18px}
  .logo-box span{color:#fff;font-weight:700;font-size:17px;letter-spacing:-0.3px}
  .header-text h1{font-size:15px;font-weight:600;color:#1a1a2e}
  .header-text p{font-size:12px;color:#999;margin-top:1px}
  .card{background:#fff;border-radius:16px;border:1px solid #eee;box-shadow:0 1px 6px rgba(0,0,0,.05);padding:24px;margin-bottom:16px}
  .section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#bbb;margin-bottom:12px}
  .drop-zone{border:2px dashed #e0deff;border-radius:12px;padding:40px 24px;text-align:center;cursor:pointer;transition:all .18s}
  .drop-zone:hover,.drop-zone.drag{border-color:#7F77DD;background:#f5f4ff}
  .drop-icon{font-size:36px;margin-bottom:10px}
  .drop-label{font-size:14px;color:#555;font-weight:500}
  .drop-sub{font-size:12px;color:#bbb;margin-top:5px}
  .file-chip{display:flex;align-items:center;gap:10px;background:#f8f7ff;border-radius:10px;padding:11px 14px;margin-top:12px;border:1px solid #ebe9ff}
  .file-chip .name{font-size:13px;font-weight:500;color:#222;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .file-chip .size{font-size:11px;color:#bbb;white-space:nowrap}
  .btn-primary{width:100%;margin-top:14px;padding:13px;border-radius:11px;font-size:14px;font-weight:600;color:#fff;background:#1a0a2e;border:none;cursor:pointer;transition:opacity .15s}
  .btn-primary:hover:not(:disabled){opacity:.85}
  .btn-primary:disabled{opacity:.35;cursor:not-allowed}
  .btn-download{width:100%;margin-top:14px;padding:13px;border-radius:11px;font-size:14px;font-weight:600;color:#fff;background:#7F77DD;border:none;cursor:pointer;transition:opacity .15s}
  .btn-download:hover{opacity:.87}
  .status{display:flex;align-items:center;gap:9px;padding:11px 14px;border-radius:10px;font-size:13px;margin-top:12px}
  .status.loading{background:#eff6ff;color:#1d4ed8}
  .status.success{background:#f0fdf4;color:#15803d}
  .status.error{background:#fef2f2;color:#dc2626}
  .spin{width:15px;height:15px;border:2px solid #bfdbfe;border-top-color:#2563eb;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
  @keyframes spin{to{transform:rotate(360deg)}}

  /* Preview */
  .preview-wrap{background:#f8f7ff;border-radius:12px;padding:20px;border:1px solid #ebe9ff}
  .inv-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:22px}
  .inv-logo{background:#1a0a2e;border-radius:7px;padding:7px 14px}
  .inv-logo span{color:#fff;font-weight:700;font-size:14px}
  .inv-title{font-size:22px;font-weight:300;color:#1a1a2e;text-align:right}
  .inv-num{display:inline-block;margin-top:5px;padding:2px 10px;border-radius:5px;font-size:11px;font-weight:700;background:#EEEDFE;color:#3C3489}
  .inv-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:16px}
  .lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#bbb;margin-bottom:5px}
  .sender-name{font-weight:700;font-size:13px;margin-bottom:2px}
  .sender-info{font-size:11px;color:#999;line-height:1.6}
  table.dtable{width:100%;font-size:11px;border-collapse:collapse}
  table.dtable td{padding:2.5px 0}
  table.dtable td:last-child{text-align:right;font-weight:600}
  table.dtable td:first-child{color:#999}
  .billtxt{font-weight:700;font-size:13px;margin-bottom:16px}
  table.items{width:100%;border-collapse:collapse;font-size:11px}
  table.items th{background:#EEEDFE;color:#3C3489;padding:7px 8px;font-weight:700;text-align:left}
  table.items th:not(:first-child){text-align:center}
  table.items th:last-child{text-align:right}
  table.items td{padding:8px;border-bottom:1px solid #f0f0f0}
  table.items td:not(:first-child){text-align:center}
  table.items td:last-child{text-align:right;font-weight:600}
  .totals-box{max-width:200px;margin-left:auto;margin-top:14px}
  .trow{display:flex;justify-content:space-between;padding:3px 0;font-size:12px}
  .trow .lk{color:#999}
  .trow.grand{font-weight:700;border-top:2px solid #ddd;padding-top:7px;margin-top:3px;font-size:14px}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const {useState} = React;

const fmt = n => "$" + parseFloat(n || 0).toFixed(2);

function App() {
  const [file, setFile] = useState(null);
  const [status, setStatus] = useState(null);
  const [converted, setConverted] = useState(null);
  const [dragging, setDragging] = useState(false);

  function handleFile(f) {
    if (!f || f.type !== "application/pdf") return;
    setFile(f); setConverted(null); setStatus(null);
  }

  function onDrop(e) {
    e.preventDefault(); setDragging(false);
    handleFile(e.dataTransfer.files[0]);
  }

  function toB64(f) {
    return new Promise((res, rej) => {
      const r = new FileReader();
      r.onload = () => res(r.result.split(",")[1]);
      r.onerror = rej;
      r.readAsDataURL(f);
    });
  }

  async function convert() {
    if (!file) return;
    setStatus({ type: "loading", msg: "Extrayendo información del PDF con IA..." });
    try {
      const b64 = await toB64(file);
      const resp = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          // ⬇ Agrega tu API key aquí para pruebas locales
          // "x-api-key": "sk-ant-..."
          // En producción esto se maneja server-side
        },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 1000,
          messages: [{
            role: "user",
            content: [
              { type: "document", source: { type: "base64", media_type: "application/pdf", data: b64 } },
              { type: "text", text: 'Extrae los datos de esta factura de Smartbeemo y responde SOLO con JSON sin markdown, con esta estructura exacta: {"invoiceNumber":"","date":"","dueDate":"","currency":"","paymentTerm":"","billTo":"","subtotal":0,"tax":0,"total":0,"balance":0,"items":[{"name":"","qty":0,"unitPrice":0,"period":"","discount":0,"total":0}]}. Reemplaza "smartBeemo" por "Graddual" en los nombres de items.' }
            ]
          }]
        })
      });
      const data = await resp.json();
      if (data.error) throw new Error(data.error.message);
      const text = (data.content || []).map(c => c.text || "").join("");
      const clean = text.replace(/```json|```/g, "").trim();
      const parsed = JSON.parse(clean);
      setConverted(parsed);
      setStatus({ type: "success", msg: "✅ Factura convertida correctamente." });
    } catch (err) {
      setStatus({ type: "error", msg: "❌ Error: " + err.message });
      console.error(err);
    }
  }

  function downloadPDF() {
    if (!converted) return;
    const d = converted;
    const rows = (d.items || []).map(item => `
      <tr>
        <td>${item.name}</td>
        <td style="text-align:center">${item.qty}</td>
        <td style="text-align:right">${fmt(item.unitPrice)}</td>
        <td style="text-align:center;font-size:11px;color:#888">${item.period}</td>
        <td style="text-align:center">${item.discount}</td>
        <td style="text-align:right;font-weight:700">${fmt(item.total)}</td>
      </tr>`).join("");

    const html = `<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8">
    <title>Factura Graddual ${d.invoiceNumber}</title>
    <style>
      @page{size:A4;margin:28mm 20mm 20mm 20mm}
      *{box-sizing:border-box;margin:0;padding:0}
      body{font-family:Arial,Helvetica,sans-serif;color:#1a1a2e;font-size:12px;background:#fff;-webkit-print-color-adjust:exact;print-color-adjust:exact}
      .page{max-width:760px;margin:0 auto;padding:24px}
      .topbar{background:#1a0a2e;color:#fff;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;font-family:Arial,sans-serif;font-size:13px}
      .topbar button{background:#7F77DD;color:#fff;border:none;padding:8px 22px;border-radius:7px;font-weight:700;cursor:pointer;font-size:13px}
      .head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;padding-bottom:18px;border-bottom:2px solid #EEEDFE}
      .logo-box{background:#1a0a2e;border-radius:8px;padding:10px 20px}
      .logo-box span{color:#fff;font-weight:700;font-size:18px}
      .inv-info{text-align:right}
      .inv-title{font-size:26px;font-weight:300;margin-bottom:6px}
      .inv-num{display:inline-block;background:#EEEDFE;color:#3C3489;border-radius:5px;padding:3px 12px;font-size:11px;font-weight:700}
      .grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-bottom:22px}
      .slabel{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:#aaa;margin-bottom:6px}
      .sender-name{font-weight:700;font-size:13px;margin-bottom:3px}
      .sender-info{font-size:12px;color:#666;line-height:1.7}
      table.dt{width:100%;font-size:12px;border-collapse:collapse}
      table.dt td{padding:3px 0}
      table.dt td:last-child{text-align:right;font-weight:600}
      table.dt td:first-child{color:#888}
      .billtxt{font-weight:700;font-size:13px;margin-bottom:20px}
      table.items{width:100%;border-collapse:collapse;font-size:12px}
      table.items thead tr{background:#EEEDFE;-webkit-print-color-adjust:exact;print-color-adjust:exact}
      table.items th{color:#3C3489;padding:9px 10px;font-weight:700;text-align:left}
      table.items th:not(:first-child){text-align:center}
      table.items th:last-child{text-align:right}
      table.items td{padding:10px;border-bottom:1px solid #f0f0f0}
      table.items td:not(:first-child){text-align:center}
      table.items td:last-child{text-align:right;font-weight:700}
      .totals{max-width:220px;margin-left:auto;margin-top:18px}
      .trow{display:flex;justify-content:space-between;padding:4px 0;font-size:12px}
      .trow .lk{color:#888}
      .trow.grand{font-weight:700;border-top:2px solid #ddd;padding-top:9px;margin-top:5px;font-size:15px}
      .footer{margin-top:40px;text-align:center;font-size:11px;color:#ccc;padding-top:16px;border-top:1px solid #f0f0f0}
      @media print{
        .topbar{display:none!important}
        body{margin:0}
      }
    </style></head><body>
    <div class="topbar">
      <span>Vista previa — Factura Graddual <strong>${d.invoiceNumber}</strong></span>
      <button onclick="window.print()">⬇ Descargar PDF</button>
    </div>
    <div class="page">
      <div class="head">
        <div class="logo-box"><span>graddual</span></div>
        <div class="inv-info">
          <div class="inv-title">INVOICE</div>
          <span class="inv-num">${d.invoiceNumber}</span>
        </div>
      </div>
      <div class="grid">
        <div>
          <p class="slabel">Emisor</p>
          <p class="sender-name">Graddual</p>
          <p class="sender-info">soporte@graddual.com<br>graddual.com</p>
        </div>
        <div>
          <p class="slabel">Detalles</p>
          <table class="dt">
            <tr><td>Fecha</td><td>${d.date}</td></tr>
            <tr><td>Moneda</td><td>${d.currency}</td></tr>
            <tr><td>Pago</td><td>${d.paymentTerm}</td></tr>
            <tr><td>Vence</td><td>${d.dueDate}</td></tr>
          </table>
        </div>
      </div>
      <p class="slabel">Facturar a</p>
      <p class="billtxt">${d.billTo}</p>
      <p class="slabel">Detalle de cargos</p>
      <table class="items">
        <thead><tr><th>Servicio</th><th>Cant.</th><th>P. Unit.</th><th>Período</th><th>Desc.</th><th>Total</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>
      <div class="totals">
        <div class="trow"><span class="lk">Subtotal</span><span>${fmt(d.subtotal)}</span></div>
        <div class="trow"><span class="lk">Impuesto</span><span>${fmt(d.tax)}</span></div>
        <div class="trow grand"><span>Total</span><span>${fmt(d.total)}</span></div>
        <div class="trow"><span class="lk">Saldo</span><span>${fmt(d.balance)}</span></div>
      </div>
      <div class="footer">Generado por Graddual · graddual.com</div>
    </div>
    </body></html>`;

    const win = window.open("", "_blank", "width=860,height=700");
    if (!win) {
      alert("El navegador bloqueó la ventana emergente.\nPermite ventanas emergentes para este sitio e intenta de nuevo.");
      return;
    }
    win.document.open();
    win.document.write(html);
    win.document.close();
  }

  return (
    <div className="app">
      <div className="header">
        <div className="logo-box"><span>graddual</span></div>
        <div className="header-text">
          <h1>Convertidor de facturas</h1>
          <p>Smartbeemo → Graddual</p>
        </div>
      </div>

      <div className="card">
        <p className="section-label">Subir factura</p>
        <div
          className={`drop-zone${dragging ? " drag" : ""}`}
          onClick={() => document.getElementById("pdf-inp").click()}
          onDragOver={e => { e.preventDefault(); setDragging(true); }}
          onDragLeave={() => setDragging(false)}
          onDrop={onDrop}
        >
          <div className="drop-icon">📄</div>
          <p className="drop-label">Haz clic o arrastra tu factura PDF aquí</p>
          <p className="drop-sub">Facturas de Smartbeemo en formato PDF</p>
        </div>
        <input id="pdf-inp" type="file" accept=".pdf" style={{display:"none"}} onChange={e => handleFile(e.target.files[0])} />

        {file && (
          <div className="file-chip">
            <span style={{fontSize:20}}>📑</span>
            <span className="name">{file.name}</span>
            <span className="size">{(file.size/1024).toFixed(0)} KB</span>
          </div>
        )}

        <button
          className="btn-primary"
          disabled={!file || status?.type === "loading"}
          onClick={convert}
        >
          {status?.type === "loading" ? "Convirtiendo..." : "Convertir a formato Graddual"}
        </button>

        {status && (
          <div className={`status ${status.type}`}>
            {status.type === "loading" && <div className="spin" />}
            <span>{status.msg}</span>
          </div>
        )}
      </div>

      {converted && (
        <div className="card">
          <p className="section-label">Vista previa — Factura Graddual</p>
          <div className="preview-wrap">
            <div className="inv-head">
              <div className="inv-logo"><span>graddual</span></div>
              <div>
                <p className="inv-title">INVOICE</p>
                <span className="inv-num">{converted.invoiceNumber}</span>
              </div>
            </div>
            <div className="inv-grid">
              <div>
                <p className="lbl">Emisor</p>
                <p className="sender-name">Graddual</p>
                <p className="sender-info">soporte@graddual.com</p>
                <p className="sender-info">graddual.com</p>
              </div>
              <div>
                <p className="lbl">Detalles</p>
                <table className="dtable">
                  <tbody>
                    {[["Fecha",converted.date],["Moneda",converted.currency],["Pago",converted.paymentTerm],["Vence",converted.dueDate]].map(([k,v]) => (
                      <tr key={k}><td>{k}</td><td>{v}</td></tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
            <p className="lbl">Facturar a</p>
            <p className="billtxt">{converted.billTo}</p>
            <p className="lbl">Detalle de cargos</p>
            <table className="items">
              <thead>
                <tr>
                  {["Servicio","Cant.","P. Unit.","Período","Desc.","Total"].map((h,i) => (
                    <th key={h} style={{textAlign:i===0?"left":i===5?"right":"center"}}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {(converted.items||[]).map((item,i) => (
                  <tr key={i}>
                    <td>{item.name}</td>
                    <td>{item.qty}</td>
                    <td style={{textAlign:"right"}}>{fmt(item.unitPrice)}</td>
                    <td style={{color:"#aaa",fontSize:10}}>{item.period}</td>
                    <td>{item.discount}</td>
                    <td style={{textAlign:"right"}}>{fmt(item.total)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div className="totals-box">
              <div className="trow"><span className="lk">Subtotal</span><span>{fmt(converted.subtotal)}</span></div>
              <div className="trow"><span className="lk">Impuesto</span><span>{fmt(converted.tax)}</span></div>
              <div className="trow grand"><span>Total</span><span>{fmt(converted.total)}</span></div>
              <div className="trow"><span className="lk">Saldo</span><span>{fmt(converted.balance)}</span></div>
            </div>
          </div>
          <button className="btn-download" onClick={downloadPDF}>
            ⬇ Ver y descargar PDF
          </button>
        </div>
      )}
    </div>
  );
}

ReactDOM.render(<App />, document.getElementById("root"));
</script>
</body>
</html>
